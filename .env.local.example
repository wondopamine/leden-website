# Supabase (required for CMS — site falls back to sample data without these)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sanity CMS (optional legacy — site works with sample data without these)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Resend (optional — for order notification emails to the cafe)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
CAFE_EMAIL=your-cafe-email@gmail.com

# Google Places API (optional — for live Google Maps rating & reviews)
# Get a key: https://console.cloud.google.com/apis/credentials
# Enable "Places API" in your Google Cloud project
# Without this key, the site shows real reviews collected from Google (Dec 2025).
# With this key, rating/reviews update automatically every 24 hours.
GOOGLE_PLACES_API_KEY=
